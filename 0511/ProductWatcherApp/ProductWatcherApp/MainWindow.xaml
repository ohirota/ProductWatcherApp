<Window x:Class="ProductWatcherApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProductWatcherApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="[商品入力エリア]" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Text="商品名:" Width="60" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtProductName" Width="200" Height="25"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text=" 価格(円):" Width="60" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtPrice" Width="200" Height="25"/>
            </StackPanel>

            <Button x:Name="BtnAdd" Content="追加ボタン" Width="100" Height="30" HorizontalAlignment="Left"/>
        </StackPanel>

            <GroupBox Grid.Row="1" Header="登録済み商品一覧" Margin="0,10,0,0">
            <DataGrid x:Name="DgProducts" ItemsSource="{Binding Products}" AutoGenerateColumns="False" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="商品名" Width="*" Binding="{Binding Path=ProductName}"/>
                        <DataGridTextColumn Header="価格" Width="100" Binding="{Binding Path=Price, StringFormat={}{0:N0}円}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
    </Grid>
</Window>
