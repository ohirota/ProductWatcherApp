<Window x:Class="Project0703.DetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Project0703"
        mc:Ignorable="d"
        Title="詳細情報" Height="250" Width="350">

    <StackPanel Margin="{StaticResource DefaultMargin}">
        <TextBlock Text="ID" FontWeight="Bold"/>
        <TextBlock Text="{Binding Id}" Margin="0,0,0,10"/>

        <TextBlock Text="ライン名" FontWeight="Bold"/>
        <TextBlock Text="{Binding LineName}" Margin="0,0,0,10"/>

        <TextBlock Text="稼働状況" FontWeight="Bold"/>
        <TextBlock Text="{Binding Status}" Margin="0,0,0,10"/>

        <TextBlock Text="担当者" FontWeight="Bold"/>
        <TextBlock Text="{Binding Manager}" Margin="0,0,0,10"/>
    </StackPanel>

</Window>
