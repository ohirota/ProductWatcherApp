<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">


    <!--マージンの定義-->

    <Thickness x:Key="SmallMargin">5</Thickness>
    <Thickness x:Key="DefaultMargin">10</Thickness>
    <Thickness x:Key="LargeMargin">20</Thickness>

    <!--<色の定義>-->

    <SolidColorBrush x:Key="PrimaryColor" Color="SteelBlue" />
    <SolidColorBrush x:Key="ActiveColor" Color="Green" />
    <SolidColorBrush x:Key="StopColor" Color="Red" />
    <SolidColorBrush x:Key="MaintenanceColor" Color="Orange" />
    
    <!--フォントサイズの定義-->

    <System:Double x:Key="DefaultFontSize" xmlns:System="clr-namespace:System;assembly=mscorlib">14</System:Double>


    <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- 🔥 追加：PrimaryButton -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="5"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

</ResourceDictionary>