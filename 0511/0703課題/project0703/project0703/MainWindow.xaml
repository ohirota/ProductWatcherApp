<Window x:Class="Project0703.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Project0703"
        mc:Ignorable="d"
        Title="製造ライン管理" Height="800" Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ヘッダー -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
        Background="{StaticResource PrimaryColor}"
        Padding="{StaticResource DefaultMargin}">
            <DockPanel LastChildFill="False">
                <TextBlock Text="製造ライン管理システム"
                   Foreground="White"
                   FontSize="{StaticResource DefaultFontSize}"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right"
                Style="{StaticResource PrimaryButton}"
                Click="ResetButton_Click">全件表示</Button>
                <Button DockPanel.Dock="Right"
                Style="{StaticResource PrimaryButton}"
                Margin="0,0,5,0"
                Click="AddLineButton_Click">ライン追加</Button>
            </DockPanel>
        </Border>


        <!-- フィルター用ドロップダウン　-->
        <ComboBox Grid.Row="1" Grid.ColumnSpan="2"
                  Width="200px"
                  HorizontalAlignment="Left"
                  Margin="{StaticResource DefaultMargin}"
                  ItemsSource="{Binding StatusList}"
                  SelectedItem="{Binding SelectedStatus}"/>


        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="{StaticResource DefaultMargin}">
            <TextBlock Text="{Binding ActiveCount,StringFormat='稼働中: {0}件' }" Margin="0,0,20,0"/>
            <TextBlock Text="{Binding StoppedCount,StringFormat='停止: {0}件' }" Margin="0,0,20,0"/>
            <TextBlock Text="{Binding MaintenanceCount,StringFormat='メンテナンス: {0}件' }"/>

        </StackPanel>

        <ItemsControl Grid.Row="3" Grid.ColumnSpan="2" 
              ItemsSource="{Binding ManagerCounts}"
              Margin="{StaticResource DefaultMargin}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Key}" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding Value, StringFormat=': {0}件  '}"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>




        <!-- 一覧表示 -->
        <DataGrid Grid.Row="4" Grid.Column="0"
                  ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                  Margin="{StaticResource DefaultMargin}"
                  FontSize="{StaticResource DefaultFontSize}"
                  ItemsSource="{Binding FilteredLines}"
                  AutoGenerateColumns="False"
                  MouseDoubleClick="DataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="150"/>
                <DataGridTextColumn Header="ライン名" Binding="{Binding LineName}" Width="150"/>
                <DataGridTextColumn Header="稼働状況" Binding="{Binding Status}" Width="150"/>
                <DataGridTextColumn Header="担当者" Binding="{Binding Manager}" Width="150"/>
            </DataGrid.Columns>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Status}" Value="稼働中">
                            <Setter Property="Background" Value="{StaticResource ActiveColor}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="停止">
                            <Setter Property="Background" Value="{StaticResource StopColor}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="メンテナンス">
                            <Setter Property="Background" Value="{StaticResource MaintenanceColor}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <DataGrid Grid.Row="4" Grid.Column="1"
          ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
          Margin="{StaticResource DefaultMargin}"
          FontSize="{StaticResource DefaultFontSize}"
          ItemsSource="{Binding ProcessLines}"
          AutoGenerateColumns="False"
          MouseDoubleClick="DataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="100"/>
                <DataGridTextColumn Header="半導体種類" Binding="{Binding Category}" Width="150"/>
                <DataGridTextColumn Header="製造段階" Binding="{Binding ProductionStage}" Width="150"/>
                <DataGridTextColumn Header="オンスケ" Binding="{Binding IsOnSchedule, Converter={StaticResource BoolToScheduleConverter}}" Width="*"/>
            </DataGrid.Columns>

        </DataGrid>

    </Grid>
</Window>
