<Window x:Class="Project0703.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Project0703"
        mc:Ignorable="d"
        Title="製造ライン管理" Height="800" Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ヘッダー -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
        Background="{StaticResource PrimaryColor}"
        Padding="{StaticResource DefaultMargin}">
            <DockPanel LastChildFill="False">
                <TextBlock Text="製造ライン管理システム"
                   Foreground="White"
                   FontSize="{StaticResource DefaultFontSize}"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right"
                Style="{StaticResource PrimaryButton}"
                Click="ResetButton_Click">全件表示</Button>
                <Button DockPanel.Dock="Right"
                Style="{StaticResource PrimaryButton}"
                Margin="0,0,5,0"
                Click="AddLineButton_Click">ライン追加</Button>
            </DockPanel>
        </Border>


        <!-- フィルター用ドロップダウン　-->
        <ComboBox Grid.Row="1" Grid.ColumnSpan="2"
                  Width="200px"
                  HorizontalAlignment="Left"
                  Margin="{StaticResource DefaultMargin}"
                  ItemsSource="{Binding StatusList}"
                  SelectedItem="{Binding SelectedStatus}"/>

        <!-- 一覧表示 -->
        <DataGrid Grid.Row="2" Grid.Column="0"
                  ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                  Margin="{StaticResource DefaultMargin}"
                  FontSize="{StaticResource DefaultFontSize}"
                  ItemsSource="{Binding FilteredLines}"
                  AutoGenerateColumns="False"
                  MouseDoubleClick="DataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="150"/>
                <DataGridTextColumn Header="ライン名" Binding="{Binding LineName}" Width="150"/>
                <DataGridTextColumn Header="稼働状況" Binding="{Binding Status}" Width="150"/>
                <DataGridTextColumn Header="担当者" Binding="{Binding Manager}" Width="150"/>
            </DataGrid.Columns>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Status}" Value="稼働中">
                            <Setter Property="Background" Value="{StaticResource ActiveColor}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="停止">
                            <Setter Property="Background" Value="{StaticResource StopColor}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="メンテナンス">
                            <Setter Property="Background" Value="{StaticResource MaintenanceColor}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <DataGrid Grid.Row="2" Grid.Column="1"
          ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
          Margin="{StaticResource DefaultMargin}"
          FontSize="{StaticResource DefaultFontSize}"
          ItemsSource="{Binding ProcessLines}"
          AutoGenerateColumns="False"
          MouseDoubleClick="DataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="100"/>
                <DataGridTextColumn Header="半導体種類" Binding="{Binding Category}" Width="150"/>
                <DataGridTextColumn Header="製造段階" Binding="{Binding ProductionStage}" Width="150"/>
                <DataGridTextColumn Header="オンスケ" Binding="{Binding IsOnSchedule, Converter={StaticResource BoolToScheduleConverter}}" Width="*"/>
            </DataGrid.Columns>

        </DataGrid>

    </Grid>
</Window>
