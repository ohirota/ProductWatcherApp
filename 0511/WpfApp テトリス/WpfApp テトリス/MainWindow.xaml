<Window x:Class="WpfApp_テトリス.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎮 テトリス風ブロック崩し" Height="650" Width="500"
        Background="#1a1a2e"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="NeonButton" TargetType="Button">
            <Setter Property="Background" Value="#16213e"/>
            <Setter Property="Foreground" Value="#00d4ff"/>
            <Setter Property="BorderBrush" Value="#00d4ff"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00d4ff"/>
                                <Setter Property="Foreground" Value="#1a1a2e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="140"/>
        </Grid.ColumnDefinitions>

        <!-- ゲームエリア -->
        <Border Grid.Column="0" Margin="10"
                BorderBrush="#00d4ff" BorderThickness="2"
                Background="#0f0f1a" CornerRadius="4">
            <Canvas x:Name="GameCanvas"
                    Width="300" Height="560"
                    Focusable="True"
                    KeyDown="GameCanvas_KeyDown"
                    ClipToBounds="True">
            </Canvas>
        </Border>

        <!-- サイドパネル -->
        <StackPanel Grid.Column="1" Margin="0,10,10,10" VerticalAlignment="Top">

            <!-- タイトル -->
            <TextBlock Text="BLOCK" FontSize="18" FontWeight="Black"
                       Foreground="#00d4ff" HorizontalAlignment="Center"
                       FontFamily="Consolas"/>
            <TextBlock Text="BREAKER" FontSize="18" FontWeight="Black"
                       Foreground="#ff006e" HorizontalAlignment="Center"
                       FontFamily="Consolas" Margin="0,0,0,15"/>

            <!-- スコア -->
            <Border Background="#16213e" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                    BorderBrush="#00d4ff" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="SCORE" FontSize="10" FontWeight="Bold"
                               Foreground="#888" FontFamily="Consolas" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="ScoreText" Text="0"
                               FontSize="22" FontWeight="Black"
                               Foreground="#00d4ff" HorizontalAlignment="Center"
                               FontFamily="Consolas"/>
                </StackPanel>
            </Border>

            <!-- レベル -->
            <Border Background="#16213e" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                    BorderBrush="#ff006e" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="LEVEL" FontSize="10" FontWeight="Bold"
                               Foreground="#888" FontFamily="Consolas" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="LevelText" Text="1"
                               FontSize="22" FontWeight="Black"
                               Foreground="#ff006e" HorizontalAlignment="Center"
                               FontFamily="Consolas"/>
                </StackPanel>
            </Border>

            <!-- ライン -->
            <Border Background="#16213e" CornerRadius="6" Padding="10,8" Margin="0,0,0,15"
                    BorderBrush="#ffd60a" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="LINES" FontSize="10" FontWeight="Bold"
                               Foreground="#888" FontFamily="Consolas" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="LinesText" Text="0"
                               FontSize="22" FontWeight="Black"
                               Foreground="#ffd60a" HorizontalAlignment="Center"
                               FontFamily="Consolas"/>
                </StackPanel>
            </Border>

            <!-- NEXT -->
            <TextBlock Text="NEXT" FontSize="11" FontWeight="Bold"
                       Foreground="#888" FontFamily="Consolas"
                       HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <Border Background="#0f0f1a" CornerRadius="6" Padding="8"
                    BorderBrush="#333" BorderThickness="1" Margin="0,0,0,15"
                    HorizontalAlignment="Center">
                <Canvas x:Name="NextCanvas" Width="80" Height="80"/>
            </Border>

            <!-- ボタン -->
            <Button x:Name="StartButton" Content="▶ START"
                    Style="{StaticResource NeonButton}"
                    Click="StartButton_Click" Margin="0,0,0,6"/>
            <Button x:Name="PauseButton" Content="⏸ PAUSE"
                    Style="{StaticResource NeonButton}"
                    Click="PauseButton_Click" IsEnabled="False" Margin="0,0,0,15"/>

            <!-- 操作説明 -->
            <Border Background="#16213e" CornerRadius="6" Padding="8"
                    BorderBrush="#333" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="CONTROLS" FontSize="9" FontWeight="Bold"
                               Foreground="#555" FontFamily="Consolas"
                               HorizontalAlignment="Center" Margin="0,0,0,5"/>
                    <TextBlock Text="← →  移動" FontSize="10" Foreground="#666" FontFamily="Consolas"/>
                    <TextBlock Text="↑   回転" FontSize="10" Foreground="#666" FontFamily="Consolas"/>
                    <TextBlock Text="↓   落下" FontSize="10" Foreground="#666" FontFamily="Consolas"/>
                    <TextBlock Text="Space ドロップ" FontSize="10" Foreground="#666" FontFamily="Consolas"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
